[Unit]
Description=RuneScape: Dragonwilds Dedicated Server
Documentation=https://dragonwilds.runescape.wiki/w/Dedicated_Servers
Wants=network-online.target
After=syslog.target network.target local-fs.target

[Service]
WorkingDirectory={{ rs_dragonwilds_install_dir }}
User={{ rs_dragonwilds_user }}
Group={{ rs_dragonwilds_user }}
{% if rs_dragonwilds_unsupported_change_max_players | bool -%}
{% set _maxplayers_opt = " -ini:Game:[/Script/Engine.GameSession]:MaxPlayers=" + rs_dragonwilds_max_players | string %}
{% else %}
{% set _maxplayers_opt = "" %}
{% endif %}
ExecStart={{ rs_dragonwilds_install_dir }}/RSDragonwildsServer.sh -log -NewConsole -Port={{ rs_dragonwilds_server_port }}{{ _maxplayers_opt }}
Type=simple
Restart=always

[Install]
WantedBy=multi-user.target
